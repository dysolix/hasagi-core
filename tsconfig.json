{
    "compilerOptions": {
        "target": "ES2022",
        "module": "node16",
        "moduleResolution": "node16",

        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true,

        "strict": true,

        "outDir": "./dist/",
        "rootDir": "./src/",
        "declaration": true,
        "removeComments": false,

        "forceConsistentCasingInFileNames": true,

        "allowSyntheticDefaultImports": true
    },
    "include": [
        "./src/",
    ]
}