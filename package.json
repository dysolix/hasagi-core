{
  "name": "@hasagi/core",
  "private": true,
  "version": "0.6.11",
  "description": "A library that makes using the League of Legends client API (LCU) easy.",
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:all": "npm run lint && npm run test:all && npm run check:package",
    "check:src": "npm run lint && npm run test:unit && npm run check:types",
    "check:package": "npm run build && publint ./dist && attw --pack ./dist",
    "check:release": "publint ./dist && attw --pack ./dist",
    "check:types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test:all": "npm run test:typecheck && vitest run",
    "test:unit": "npm run test:typecheck && vitest run tests/unit",
    "test:integration": "npm run test:typecheck && vitest run tests/integration",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "release": "npm run check:src && npm run build && npm run check:release && cd ./dist && npm publish --access public",
    "update-types": "hasagi schema --typescript ./src/types"
  },
  "author": "dysolix",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "hasagi",
    "league-of-legends",
    "league",
    "lol",
    "lcu",
    "lcu-api",
    "league-client",
    "typescript"
  ],
  "dependencies": {
    "axios": "^1.17.0",
    "tiny-typed-emitter": "^2.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@hasagi/cli": "^0.9.9",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "publint": "^0.3.21",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./types": {
      "types": "./types/index.d.ts"
    },
    "./credentials": {
      "types": "./credentials.d.ts",
      "default": "./credentials.js"
    }
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "typesVersions": {
    "*": {
      "types": [
        "./types/index.d.ts"
      ],
      "credentials": [
        "./credentials.d.ts"
      ]
    }
  },
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dysolix/hasagi-core.git"
  },
  "bugs": {
    "url": "https://github.com/dysolix/hasagi-core/issues"
  },
  "homepage": "https://github.com/dysolix/hasagi-core#readme"
}
